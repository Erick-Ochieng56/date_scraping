[
  {
    "name": "Eventbrite - Tech Events",
    "start_url": "https://www.eventbrite.com/d/united-states/tech/events/",
    "enabled": true,
    "target_type": "html",
    "run_every_minutes": 120,
    "config": {
      "item_selector": ".event-card",
      "fields": {
        "event_name": "h3",
        "source_url": "a.event-card-link@href"
      },
      "next_page_selector": "a.pagination-next, a[aria-label='Next'], [data-testid='pagination-next']",
      "max_pages": 5,
      "timeout_seconds": 30
    }
  },
  {
    "name": "Meetup - Local Events",
    "start_url": "https://www.meetup.com/find/events/",
    "enabled": true,
    "target_type": "playwright",
    "run_every_minutes": 180,
    "config": {
      "item_selector": "[data-element-name='event-card'], li[data-testid='event-card'], .event-card",
      "fields": {
        "full_name": "[data-element-name='event-title'], [data-testid='event-title'], h2, h3",
        "event_date": "time[datetime], [data-element-name='event-date'], [data-testid='event-date']",
        "event_name": "[data-element-name='event-description'], [data-testid='event-description'], p",
        "source_url": "a@href"
      },
      "wait_for_selector": "[data-element-name='event-card'], [data-testid='event-card']",
      "next_page_selector": "a[data-testid='pagination-next'], .pagination-next",
      "max_pages": 3,
      "timeout_seconds": 90,
      "wait_until": "domcontentloaded",
      "playwright_headless": true,
      "playwright_user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36",
      "playwright_extra_headers": {
        "Accept-Language": "en-US,en;q=0.9"
      }
    }
  },
  {
    "name": "Generic Event Site Example",
    "start_url": "https://example.com/events",
    "enabled": false,
    "target_type": "html",
    "run_every_minutes": 60,
    "config": {
      "item_selector": ".event-item, .event, .listing",
      "fields": {
        "full_name": ".event-name, .title, h2, h3",
        "email": ".event-email, [type='email']",
        "phone": ".event-phone, .phone",
        "event_date": ".event-date, .date, [datetime]",
        "event_name": ".event-description, .description",
        "source_url": "a.event-link@href, a@href"
      },
      "next_page_selector": ".pagination .next, a.next-page",
      "max_pages": 10,
      "timeout_seconds": 30
    }
  }
]